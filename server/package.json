{
  "name": "baby-tracker-server",
  "version": "1.0.0",
  "description": "Backend server for baby tracker",
  "main": "dist/index.js",
  "scripts": {
    "dev": "set PORT=4001&& ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "ncc build src/index.ts -o dist -m",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.0",
    "@vercel/ncc": "^0.44.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
